# Dependencies
node_modules/

# Database files
# NOTE: src/data/lorcana.sqlite IS tracked in git for Glama auto-rebuild compat
# (Glama clones the repo and runs the build — gitignored data files won't exist).
# Refresh the bundled database via `npm run fetch-data` before publishing.
*.sqlite-shm
*.sqlite-wal
*.db
vendor/
.venv/
__pycache__/
*.pyc

# Build output
dist/
build/
out/
.build/
*.o
*.a
*.so
*.dylib

# Environment
.env
.env.local
.env.*.local

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test output
coverage/
.coverage
*.lcov

# Platform-specific
# iOS
*.xcworkspace/xcuserdata/
DerivedData/
*.ipa

# Android
*.apk
*.aab
local.properties

# MCP Registry tokens (created by mcp-publisher CLI)
.mcpregistry_*

# MCP QA reports (per-session artefacts)
.mcp-qa/

# Misc
*.tmp
*.bak
